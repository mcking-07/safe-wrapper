{
  "name": "safe-wrapper",
  "version": "4.2.0",
  "description": "a ts-util for safely wrapping synchronous and asynchronous functions to handle errors based on specified types.",
  "type": "module",
  "main": "lib/index.cjs",
  "types": "lib/index.d.ts",
  "module": "lib/index.mjs",
  "scripts": {
    "build": "rm -rf lib && tsx esbuild.config.ts",
    "ci": "npm ci && npm test && npm run build",
    "start": "tsx src/index.ts",
    "test": "tsx --test"
  },
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "types": "./lib/index.d.ts",
      "require": "./lib/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcking-07/safe-wrapper.git"
  },
  "keywords": [
    "error",
    "wrapper",
    "safe",
    "async",
    "sync"
  ],
  "author": "mcking-07",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mcking-07/safe-wrapper/issues"
  },
  "homepage": "https://github.com/mcking-07/safe-wrapper#readme",
  "devDependencies": {
    "@types/node": "25.9.1",
    "esbuild": "0.28.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
